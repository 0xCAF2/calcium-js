{
  "name": "calcium-js",
  "version": "0.9.0",
  "description": "A Calcium language interpreter on JavaScript.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/0xCAF2/calcium-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xCAF2/calcium-js.git"
  },
  "author": "Roki Turner <roki@0xcaf2.dev>",
  "files": [
    "dist",
    "dist/tool",
    "dist/web"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tool": {
      "import": "./dist/tool/index.js",
      "types": "./dist/tool/index.d.ts"
    },
    "./web": {
      "import": "./dist/web/index.js",
      "types": "./dist/web/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "calcium",
    "language",
    "interpreter"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp && npm publish"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "bumpp": "^11.0.0",
    "tsdown": "^0.21.0",
    "vite": "^8.0.7",
    "vitest": "^4.0.6"
  },
  "peerDependencies": {
    "preact": "^10.29.1",
    "@preact/signals": "^2.9.0",
    "blockly": "^12.5.1",
    "typescript": "^5"
  }
}
